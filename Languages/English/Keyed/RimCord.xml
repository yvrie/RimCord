    <RimCord_EnableRichPresence>Enable Rich Presence</RimCord_EnableRichPresence>
    <RimCord_EnableRichPresenceDesc>Master toggle for Discord Rich Presence integration</RimCord_EnableRichPresenceDesc>
    
    <RimCord_ShowColonyName>Show Colony Name</RimCord_ShowColonyName>
    <RimCord_ShowColonyNameDesc>Display your colony name in Discord status</RimCord_ShowColonyNameDesc>
    
    <RimCord_ShowColonistCount>Show Colonist Count</RimCord_ShowColonistCount>
