    <RimCord_ShowLetterEvents>Show Letter Events</RimCord_ShowLetterEvents>
    <RimCord_ShowLetterEventsDesc>Display letter events and recent event fallback in Discord status</RimCord_ShowLetterEventsDesc>
    <RimCord_ShowThreatAlerts>Show Threat Alerts</RimCord_ShowThreatAlerts>
    <RimCord_ShowThreatAlertsDesc>Display raid and mental break alerts in Discord status</RimCord_ShowThreatAlertsDesc>
    <RimCord_ShowGameConditions>Show Game Conditions</RimCord_ShowGameConditions>
    <RimCord_ShowGameConditionsDesc>Display active game conditions like Toxic Fallout or Solar Flare in Discord status</RimCord_ShowGameConditionsDesc>
    
    
    <RimCord_EnableCustomButton>Enable custom Discord button</RimCord_EnableCustomButton>
    <RimCord_EnableCustomButtonDesc>Adds a clickable button to your Rich Presence (Twitch, Patreon, etc.)</RimCord_EnableCustomButtonDesc>
    <RimCord_ButtonNote>Note: Buttons are only visible to others viewing your profile, not to yourself.</RimCord_ButtonNote>
